---
import SEOHead from '../components/SEOHead.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  structuredData?: object | object[];
  noindex?: boolean;
}

const { title, description, ogImage = 'https://images.unsplash.com/photo-1518611012118-696072aa579a?w=1200&q=80', structuredData, noindex } = Astro.props;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': 'https://coreandflowpilates.com/#business',
  name: 'Core & Flow Pilates Studio',
  url: import.meta.env.PUBLIC_SITE_URL || 'https://coreandflowpilates.com',
  telephone: '+1-512-555-0148',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '1815 S Congress Ave, Suite 220',
    addressLocality: 'Austin',
    addressRegion: 'TX',
    postalCode: '78704',
    addressCountry: 'US',
  },
  areaServed: 'Austin, TX',
  priceRange: '$$',
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday'], opens: '06:00', closes: '19:30' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Saturday','Sunday'], opens: '08:00', closes: '14:00' },
  ],
};

const schemaData = Array.isArray(structuredData)
  ? [...structuredData, localBusinessSchema]
  : structuredData
  ? [structuredData, localBusinessSchema]
  : [localBusinessSchema];

const navLinks = [
  { href: '/classes', label: 'Classes' },
  { href: '/instructors', label: 'Instructors' },
  { href: '/schedule', label: 'Schedule' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/about', label: 'About' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead title={title} description={description} ogImage={ogImage} structuredData={schemaData} noindex={noindex} />
  </head>
  <body class="bg-paper text-ink font-body antialiased">
    <header id="site-header" class="sticky top-0 z-40 border-b border-transparent transition-all duration-200">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
        <a href="/" class="font-display text-xl font-semibold tracking-tight text-ink">
          Core <span class="text-accent">&amp;</span> Flow
        </a>
        <div class="hidden items-center gap-8 md:flex">
          {navLinks.map((l) => (
            <a href={l.href} class="text-sm text-ink/80 hover:text-accent transition-colors">{l.label}</a>
          ))}
        </div>
        <div class="flex items-center gap-4">
          <a href="/contact" class="hidden text-sm text-ink/80 hover:text-accent transition-colors sm:inline">Contact</a>
          <a href="/book" class="rounded-full bg-ink px-5 py-2.5 text-sm font-medium text-paper transition-all hover:bg-accent hover:-translate-y-0.5">
            Book a class
          </a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-line bg-ink text-paper/80">
      <div class="mx-auto grid max-w-6xl gap-10 px-6 py-16 md:grid-cols-4">
        <div>
          <p class="font-display text-lg font-semibold text-paper">Core &amp; Flow Pilates Studio</p>
          <p class="mt-3 text-sm leading-relaxed text-paper/60">
            Boutique reformer and mat Pilates in the heart of South Congress, Austin.
          </p>
        </div>
        <div>
          <p class="text-sm font-medium text-paper">Studio</p>
          <ul class="mt-3 space-y-2 text-sm text-paper/60">
            <li><a href="/classes" class="hover:text-accent transition-colors">Classes</a></li>
            <li><a href="/instructors" class="hover:text-accent transition-colors">Instructors</a></li>
            <li><a href="/schedule" class="hover:text-accent transition-colors">Schedule</a></li>
            <li><a href="/pricing" class="hover:text-accent transition-colors">Pricing</a></li>
          </ul>
        </div>
        <div>
          <p class="text-sm font-medium text-paper">Visit</p>
          <address class="mt-3 space-y-1 text-sm not-italic text-paper/60">
            <p>1815 S Congress Ave, Suite 220</p>
            <p>Austin, TX 78704</p>
            <p><a href="tel:+15125550148" class="hover:text-accent transition-colors">(512) 555-0148</a></p>
            <p><a href="mailto:hello@coreandflowpilates.com" class="hover:text-accent transition-colors">hello@coreandflowpilates.com</a></p>
          </address>
        </div>
        <div>
          <p class="text-sm font-medium text-paper">Hours</p>
          <ul class="mt-3 space-y-1 text-sm text-paper/60">
            <li>Mon–Fri: 6:00am – 7:30pm</li>
            <li>Sat–Sun: 8:00am – 2:00pm</li>
          </ul>
        </div>
      </div>
      <div class="border-t border-paper/10 py-6">
        <p class="mx-auto max-w-6xl px-6 text-xs text-paper/40">
          &copy; 2026 Core &amp; Flow Pilates Studio. All rights reserved.
        </p>
      </div>
    </footer>

    <script>
      const header = document.getElementById('site-header');
      const onScroll = () => {
        if (!header) return;
        if (window.scrollY > 24) {
          header.classList.add('backdrop-blur-md', 'bg-paper/90', 'border-line');
        } else {
          header.classList.remove('backdrop-blur-md', 'bg-paper/90', 'border-line');
        }
      };
      document.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    </script>
  </body>
</html>
