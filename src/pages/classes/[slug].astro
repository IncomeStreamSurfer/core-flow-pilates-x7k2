---
import Base from '../../layouts/Base.astro';
import { anonClient } from '../../lib/supabase';
import { CLASS_TYPES, CLASS_FAQS, INSTRUCTORS } from '../../lib/data';

export const prerender = false;

const { slug } = Astro.params;

const SEO_META: Record<string, { title: string; description: string; h1: string }> = {
  'reformer-pilates': {
    title: 'Reformer Pilates Austin | Core & Flow',
    description: 'Build strength and flexibility with reformer Pilates in Austin. Small group classes led by certified instructors — book your spot now.',
    h1: 'Reformer Pilates Classes in Austin',
  },
  'mat-pilates': {
    title: 'Mat Pilates Classes Austin | Core & Flow',
    description: 'Low-impact, high-results mat Pilates classes in Austin for all fitness levels. Reserve your spot online today.',
    h1: 'Mat Pilates Classes in Austin',
  },
  'prenatal-pilates': {
    title: 'Prenatal Pilates Austin | Core & Flow',
    description: 'Safe, supportive prenatal Pilates classes in Austin designed for every trimester. Book your class with our certified instructors.',
    h1: 'Prenatal Pilates Classes in Austin',
  },
  'barre-fusion': {
    title: 'Barre Fusion Pilates Austin | Core & Flow',
    description: 'Combine barre and Pilates in our high-energy Barre Fusion classes in Austin. Sign up and book your session today.',
    h1: 'Barre Fusion Classes in Austin',
  },
  'private-sessions': {
    title: 'Private Pilates Sessions Austin | Core & Flow',
    description: 'Get personalized attention with one-on-one private Pilates sessions in Austin. Book your private session with a certified instructor.',
    h1: 'Private Pilates Sessions in Austin',
  },
};

const meta = slug ? SEO_META[slug] : undefined;
if (!meta) {
  return new Response('Not found', { status: 404 });
}

const sb = anonClient();
let cls: any = CLASS_TYPES.find((c) => c.slug === slug);
if (sb) {
  const { data } = await sb.from('classes').select('*').eq('slug', slug).maybeSingle();
  if (data) cls = data;
}
if (!cls) {
  return new Response('Not found', { status: 404 });
}

const faqs = CLASS_FAQS[slug!] ?? [];
const relatedInstructors = INSTRUCTORS.filter((i) => i.specialties.some((s) => s.toLowerCase().includes(cls.name.split(' ')[0].toLowerCase()))).slice(0, 3);
const instructorsToShow = relatedInstructors.length ? relatedInstructors : INSTRUCTORS.slice(0, 3);

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://coreandflowpilates.com';
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: cls.name,
    description: cls.short_description,
    provider: { '@type': 'LocalBusiness', name: 'Core & Flow Pilates Studio' },
    areaServed: { '@type': 'City', name: 'Austin, TX' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Classes', item: `${siteUrl}/classes` },
      { '@type': 'ListItem', position: 3, name: cls.name, item: `${siteUrl}/classes/${slug}` },
    ],
  },
];
---

<Base title={meta.title} description={meta.description} structuredData={structuredData}>
  <nav class="mx-auto max-w-4xl px-6 pt-8 text-xs text-muted">
    <a href="/classes" class="hover:text-accent">Classes</a> <span class="mx-1">/</span> <span class="text-ink">{cls.name}</span>
  </nav>

  <section class="mx-auto grid max-w-6xl gap-10 px-6 pb-12 pt-6 md:grid-cols-2 md:items-center">
    <div>
      <h1 class="font-display text-4xl font-semibold tracking-tight text-ink sm:text-5xl">{meta.h1}</h1>
      <p class="mt-5 text-lg leading-relaxed text-muted">{cls.description}</p>
      <div class="mt-8 flex flex-wrap gap-6 border-y border-line py-5 text-sm text-muted">
        <div><span class="font-display text-xl text-ink">{cls.duration_minutes}</span> min</div>
        <div><span class="font-display text-xl text-ink">${(cls.price_cents / 100).toFixed(0)}</span> per class</div>
        <div><span class="font-display text-xl text-ink">{cls.level}</span></div>
      </div>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href={`/book?class=${cls.slug}`} class="rounded-full bg-accent px-7 py-3.5 text-sm font-medium text-paper transition-all hover:bg-accent-dark hover:-translate-y-0.5">Book this class</a>
        <a href="/schedule" class="rounded-full border border-ink px-7 py-3.5 text-sm font-medium text-ink transition-all hover:bg-ink hover:text-paper">See schedule</a>
      </div>
    </div>
    <div class="aspect-[4/5] overflow-hidden rounded-lg border border-line">
      <img src={cls.image_url} alt={`Client practicing ${cls.name} at Core & Flow Pilates Studio in Austin`} class="h-full w-full object-cover" loading="eager" />
    </div>
  </section>

  <section class="border-t border-line bg-[#f3ece1]">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-accent">Who's teaching</p>
      <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-ink">Instructors for this class</h2>
      <div class="mt-8 grid gap-8 sm:grid-cols-3">
        {instructorsToShow.map((i) => (
          <a href={`/instructors/${i.slug}`} class="group block">
            <div class="aspect-square overflow-hidden rounded-lg border border-line">
              <img src={i.image_url} alt={`${i.name}, Pilates instructor at Core & Flow Studio`} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
            </div>
            <p class="mt-3 font-display text-lg text-ink group-hover:text-accent">{i.name}</p>
            <p class="text-xs text-muted">{i.role}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-16">
    <h2 class="font-display text-3xl font-semibold tracking-tight text-ink">Frequently asked questions</h2>
    <div class="mt-8 divide-y divide-line border-y border-line">
      {faqs.map((f) => (
        <details class="group py-5">
          <summary class="flex cursor-pointer list-none items-center justify-between font-medium text-ink">
            {f.question}
            <span class="ml-4 text-accent transition-transform group-open:rotate-45">+</span>
          </summary>
          <p class="mt-3 text-sm leading-relaxed text-muted">{f.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-16 text-center">
      <h2 class="font-display text-3xl font-semibold tracking-tight text-ink">Ready to try {cls.name}?</h2>
      <p class="mx-auto mt-3 max-w-md text-muted">Check <a href="/pricing" class="text-ink underline decoration-line underline-offset-4 hover:text-accent">pricing &amp; packages</a> or book your first class now.</p>
      <a href={`/book?class=${cls.slug}`} class="mt-8 inline-block rounded-full bg-accent px-8 py-3.5 text-sm font-medium text-paper transition-all hover:bg-accent-dark hover:-translate-y-0.5">Book {cls.name}</a>
    </div>
  </section>
</Base>
