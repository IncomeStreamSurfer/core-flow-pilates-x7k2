---
import Base from '../layouts/Base.astro';
import { anonClient } from '../lib/supabase';
import { generateWeekSchedule, groupByDay, type SessionSlot } from '../lib/schedule';

export const prerender = false;

const sb = anonClient();
let slots: SessionSlot[] = [];
let fromSupabase = false;

if (sb) {
  const { data } = await sb
    .from('class_sessions')
    .select('id, starts_at, ends_at, capacity, booked_count, classes(name, slug, price_cents), instructors(name, slug)')
    .eq('status', 'scheduled')
    .gte('starts_at', new Date().toISOString())
    .order('starts_at', { ascending: true })
    .limit(60);
  if (data && data.length) {
    fromSupabase = true;
    slots = data.map((row: any) => ({
      id: row.id,
      classSlug: row.classes?.slug ?? '',
      className: row.classes?.name ?? 'Class',
      instructorSlug: row.instructors?.slug ?? '',
      instructorName: row.instructors?.name ?? 'TBD',
      startsAt: new Date(row.starts_at),
      endsAt: new Date(row.ends_at),
      capacity: row.capacity,
      bookedCount: row.booked_count,
      priceCents: row.classes?.price_cents ?? 0,
    }));
  }
}

if (!slots.length) {
  slots = generateWeekSchedule(9);
}

const grouped = groupByDay(slots);

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://coreandflowpilates.com';
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Schedule', item: `${siteUrl}/schedule` },
  ],
};
---

<Base
  title="Class Schedule | Core & Flow Pilates Studio Austin"
  description="See this week's Pilates class schedule in Austin — reformer, mat, prenatal, and barre fusion. Book your spot online in seconds."
  structuredData={structuredData}
>
  <section class="mx-auto max-w-6xl px-6 pb-8 pt-16">
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-accent">Book online</p>
    <h1 class="mt-3 font-display text-5xl font-semibold tracking-tight text-ink">This week's class schedule</h1>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-muted">
      Real-time availability for every reformer, mat, prenatal, and barre fusion class at our South Congress studio. Tap any slot to reserve it &mdash; payment is secured through Stripe at checkout.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-8">
    <div class="space-y-10">
      {Object.entries(grouped).map(([day, daySlots]) => (
        <div>
          <h2 class="font-display text-2xl text-ink">{day}</h2>
          <div class="mt-4 divide-y divide-line border-y border-line">
            {daySlots.map((s) => {
              const spotsLeft = s.capacity - s.bookedCount;
              const isFull = spotsLeft < 1;
              return (
                <div class="flex flex-wrap items-center justify-between gap-4 py-4">
                  <div class="flex items-baseline gap-6">
                    <p class="w-20 shrink-0 font-display text-lg text-ink">
                      {s.startsAt.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' })}
                    </p>
                    <div>
                      <a href={`/classes/${s.classSlug}`} class="font-medium text-ink hover:text-accent">{s.className}</a>
                      <p class="text-sm text-muted">with <a href={`/instructors/${s.instructorSlug}`} class="hover:text-accent">{s.instructorName}</a> &middot; {Math.round((s.endsAt.getTime()-s.startsAt.getTime())/60000)} min</p>
                    </div>
                  </div>
                  <div class="flex items-center gap-4">
                    <p class:list={["text-xs font-medium uppercase tracking-wide", isFull ? "text-muted" : "text-accent"]}>
                      {isFull ? 'Full' : `${spotsLeft} spot${spotsLeft === 1 ? '' : 's'} left`}
                    </p>
                    {isFull ? (
                      <span class="rounded-full border border-line px-5 py-2 text-sm text-muted">Full</span>
                    ) : (
                      <a href={`/book?session=${encodeURIComponent(s.id)}`} class="rounded-full bg-ink px-5 py-2 text-sm font-medium text-paper transition-all hover:bg-accent hover:-translate-y-0.5">
                        Book &middot; ${(s.priceCents / 100).toFixed(0)}
                      </a>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="border-t border-line bg-[#f3ece1]">
    <div class="mx-auto max-w-6xl px-6 py-14 text-center">
      <h2 class="font-display text-2xl font-semibold tracking-tight text-ink">Prefer one-on-one attention?</h2>
      <p class="mt-2 text-muted">Book a <a href="/classes/private-sessions" class="text-ink underline decoration-line underline-offset-4 hover:text-accent">private session</a> at a time that works for you.</p>
    </div>
  </section>
</Base>
