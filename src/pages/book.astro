---
import Base from '../layouts/Base.astro';
import { anonClient } from '../lib/supabase';
import { CLASS_TYPES, findClassBySlug } from '../lib/data';
import { generateWeekSchedule, findSlotById, type SessionSlot } from '../lib/schedule';

export const prerender = false;

const sessionParam = Astro.url.searchParams.get('session');
const classParam = Astro.url.searchParams.get('class');

let preselected: SessionSlot | undefined;
let slots: SessionSlot[] = [];

const sb = anonClient();
if (sessionParam) {
  // try real Supabase session first
  if (sb && !sessionParam.includes('__')) {
    const { data } = await sb
      .from('class_sessions')
      .select('id, starts_at, ends_at, capacity, booked_count, classes(name, slug, price_cents), instructors(name, slug)')
      .eq('id', sessionParam)
      .maybeSingle();
    if (data) {
      preselected = {
        id: data.id,
        classSlug: (data as any).classes?.slug ?? '',
        className: (data as any).classes?.name ?? 'Class',
        instructorSlug: (data as any).instructors?.slug ?? '',
        instructorName: (data as any).instructors?.name ?? 'TBD',
        startsAt: new Date(data.starts_at),
        endsAt: new Date(data.ends_at),
        capacity: data.capacity,
        bookedCount: data.booked_count,
        priceCents: (data as any).classes?.price_cents ?? 0,
      };
    }
  }
  if (!preselected) {
    preselected = findSlotById(sessionParam);
  }
}

slots = generateWeekSchedule(9).filter((s) => (classParam ? s.classSlug === classParam : true)).slice(0, 20);

const renderedAt = Date.now();

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://coreandflowpilates.com';
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Book a class', item: `${siteUrl}/book` },
  ],
};
---

<Base
  title="Book a Pilates Class Online | Core & Flow Austin"
  description="Reserve your Pilates class at Core & Flow Studio in Austin. Secure online payment, instant confirmation."
  structuredData={structuredData}
>
  <section class="mx-auto max-w-3xl px-6 pb-8 pt-16">
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-accent">Reserve your spot</p>
    <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight text-ink sm:text-5xl">Book your class</h1>
    <p class="mt-5 text-lg leading-relaxed text-muted">
      Choose a time below, tell us a little about you, and pay securely through Stripe. You'll get an instant email confirmation with everything you need to know before you arrive.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-8">
    <form id="booking-form" class="space-y-8 rounded-lg border border-line p-6 sm:p-8">
      <input type="hidden" name="renderedAt" value={renderedAt} />
      <input type="text" name="website" aria-hidden="true" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0" />

      <div>
        <label for="slot-select" class="block text-sm font-medium text-ink">Choose a class time</label>
        <select id="slot-select" name="slot_id" required class="mt-2 w-full rounded-md border border-line bg-paper px-4 py-3 text-sm text-ink focus:border-accent focus:outline-none">
          <option value="" disabled selected={!preselected}>Select an available class&hellip;</option>
          {slots.map((s) => (
            <option
              value={s.id}
              data-class-slug={s.classSlug}
              data-class-name={s.className}
              data-instructor-name={s.instructorName}
              data-starts-at={s.startsAt.toISOString()}
              data-ends-at={s.endsAt.toISOString()}
              data-price-cents={s.priceCents}
              selected={preselected?.id === s.id}
            >
              {s.startsAt.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' })} &middot; {s.startsAt.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' })} &mdash; {s.className} with {s.instructorName} (${(s.priceCents/100).toFixed(0)})
            </option>
          ))}
        </select>
        <p class="mt-2 text-xs text-muted">Don't see a time that works? View the <a href="/schedule" class="underline decoration-line underline-offset-4 hover:text-accent">full schedule</a>.</p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <label for="name" class="block text-sm font-medium text-ink">Full name</label>
          <input id="name" name="name" type="text" required class="mt-2 w-full rounded-md border border-line bg-paper px-4 py-3 text-sm text-ink focus:border-accent focus:outline-none" />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-ink">Email</label>
          <input id="email" name="email" type="email" required class="mt-2 w-full rounded-md border border-line bg-paper px-4 py-3 text-sm text-ink focus:border-accent focus:outline-none" />
        </div>
      </div>
      <div>
        <label for="phone" class="block text-sm font-medium text-ink">Phone (optional)</label>
        <input id="phone" name="phone" type="tel" class="mt-2 w-full rounded-md border border-line bg-paper px-4 py-3 text-sm text-ink focus:border-accent focus:outline-none" />
      </div>
      <div>
        <label for="notes" class="block text-sm font-medium text-ink">Anything we should know? (injuries, first-time, etc.)</label>
        <textarea id="notes" name="notes" rows="3" class="mt-2 w-full rounded-md border border-line bg-paper px-4 py-3 text-sm text-ink focus:border-accent focus:outline-none"></textarea>
      </div>

      <button type="submit" id="booking-submit" class="w-full rounded-full bg-accent px-8 py-4 text-sm font-medium text-paper transition-all hover:bg-accent-dark disabled:opacity-60">
        Continue to secure payment
      </button>
      <p id="booking-error" class="hidden text-sm text-red-700"></p>
      <p class="text-center text-xs text-muted">Payment is processed securely by Stripe. You can cancel or reschedule up to 6 hours before class.</p>
    </form>
  </section>

  <script define:vars={{ preselectedId: preselected?.id ?? null }}>
    const form = document.getElementById('booking-form');
    const select = document.getElementById('slot-select');
    const submitBtn = document.getElementById('booking-submit');
    const errorEl = document.getElementById('booking-error');

    if (preselectedId && select) {
      select.value = preselectedId;
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.classList.add('hidden');
      const opt = select.options[select.selectedIndex];
      if (!opt || !opt.value) {
        errorEl.textContent = 'Please choose a class time.';
        errorEl.classList.remove('hidden');
        return;
      }
      submitBtn.disabled = true;
      submitBtn.textContent = 'Redirecting to payment…';

      const fd = new FormData(form);
      const payload = {
        renderedAt: fd.get('renderedAt'),
        website: fd.get('website'),
        session_id: opt.value,
        class_slug: opt.dataset.classSlug,
        class_name: opt.dataset.className,
        instructor_name: opt.dataset.instructorName,
        session_starts_at: opt.dataset.startsAt,
        session_ends_at: opt.dataset.endsAt,
        customer_name: fd.get('name'),
        customer_email: fd.get('email'),
        customer_phone: fd.get('phone'),
        notes: fd.get('notes'),
      };

      try {
        const res = await fetch('/api/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const json = await res.json();
        if (!res.ok || json.error || !json.url) {
          throw new Error(json.error || 'Something went wrong. Please try again.');
        }
        window.location.href = json.url;
      } catch (err) {
        errorEl.textContent = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
        errorEl.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Continue to secure payment';
      }
    });
  </script>
</Base>
