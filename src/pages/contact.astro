---
import Base from '../layouts/Base.astro';

const renderedAt = Date.now();
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://coreandflowpilates.com';
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact Core & Flow Pilates Studio',
    url: `${siteUrl}/contact`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Contact', item: `${siteUrl}/contact` },
    ],
  },
];
---

<Base
  title="Contact Us | Core & Flow Pilates Studio Austin"
  description="Questions about classes, private sessions, or membership? Contact Core & Flow Pilates Studio in Austin, TX."
  structuredData={structuredData}
>
  <section class="mx-auto grid max-w-6xl gap-12 px-6 py-16 md:grid-cols-2">
    <div>
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-accent">Get in touch</p>
      <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight text-ink sm:text-5xl">We'd love to hear from you</h1>
      <p class="mt-6 max-w-md text-lg leading-relaxed text-muted">
        Questions about a class, a private session, or whether Pilates is right for you? Send us a note — we reply within one business day.
      </p>
      <div class="mt-10 space-y-4 border-t border-line pt-8 text-sm text-muted">
        <p><span class="font-medium text-ink">Address:</span> 1815 S Congress Ave, Suite 220, Austin, TX 78704</p>
        <p><span class="font-medium text-ink">Phone:</span> <a href="tel:+15125550148" class="hover:text-accent">(512) 555-0148</a></p>
        <p><span class="font-medium text-ink">Email:</span> <a href="mailto:hello@coreandflowpilates.com" class="hover:text-accent">hello@coreandflowpilates.com</a></p>
        <p><span class="font-medium text-ink">Hours:</span> Mon&ndash;Fri 6am&ndash;7:30pm, Sat&ndash;Sun 8am&ndash;2pm</p>
        <a
          href="https://www.google.com/maps/search/?api=1&query=1815+S+Congress+Ave+Suite+220+Austin+TX+78704"
          target="_blank"
          rel="noopener"
          class="inline-block text-ink underline decoration-line underline-offset-4 hover:text-accent"
        >Get directions &rarr;</a>
      </div>
    </div>

    <form id="contact-form" method="POST" action="/api/contact" class="space-y-5 rounded-lg border border-line p-6 sm:p-8">
      <input type="hidden" name="renderedAt" value={renderedAt} />
      <input type="text" name="website" aria-hidden="true" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0" />
      <div>
        <label for="name" class="block text-sm font-medium text-ink">Name</label>
        <input id="name" name="name" type="text" required class="mt-2 w-full rounded-md border border-line bg-paper px-4 py-3 text-sm text-ink focus:border-accent focus:outline-none" />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-ink">Email</label>
        <input id="email" name="email" type="email" required class="mt-2 w-full rounded-md border border-line bg-paper px-4 py-3 text-sm text-ink focus:border-accent focus:outline-none" />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium text-ink">Message</label>
        <textarea id="message" name="message" rows="5" required class="mt-2 w-full rounded-md border border-line bg-paper px-4 py-3 text-sm text-ink focus:border-accent focus:outline-none"></textarea>
      </div>
      <button type="submit" id="contact-submit" class="w-full rounded-full bg-accent px-8 py-3.5 text-sm font-medium text-paper transition-all hover:bg-accent-dark">
        Send message
      </button>
      <p id="contact-status" class="hidden text-sm"></p>
    </form>
  </section>
</Base>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('contact-status');
  const btn = document.getElementById('contact-submit') as HTMLButtonElement | null;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status || !btn) return;
    status.classList.add('hidden');
    btn.disabled = true;
    btn.textContent = 'Sending…';
    const body = Object.fromEntries(new FormData(form).entries());
    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const json = await res.json();
      if (!res.ok || json.error) throw new Error(json.error || 'Something went wrong');
      status.textContent = "Thanks — we'll be in touch within one business day.";
      status.className = 'text-sm text-accent';
      status.classList.remove('hidden');
      form.reset();
    } catch (err) {
      status.textContent = err instanceof Error ? err.message : 'Something went wrong';
      status.className = 'text-sm text-red-700';
      status.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send message';
    }
  });
</script>
