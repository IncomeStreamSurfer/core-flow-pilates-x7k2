---
import Base from '../../layouts/Base.astro';
---

<Base title="Booking Cancelled | Core & Flow Pilates Studio" description="Your booking was not completed." noindex={true}>
  <section class="mx-auto max-w-xl px-6 py-24 text-center">
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-accent">No charge made</p>
    <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight text-ink">Your spot is still open</h1>
    <p class="mt-6 text-lg leading-relaxed text-muted">
      You cancelled checkout before payment — no charge was made. The class time you picked hasn't been reserved, so grab it again whenever you're ready.
    </p>
    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a href="/schedule" class="rounded-full bg-accent px-6 py-3 text-sm font-medium text-paper transition-all hover:bg-accent-dark hover:-translate-y-0.5">Back to schedule</a>
      <a href="/contact" class="rounded-full border border-ink px-6 py-3 text-sm font-medium text-ink transition-all hover:bg-ink hover:text-paper">Contact us</a>
    </div>
  </section>
</Base>
